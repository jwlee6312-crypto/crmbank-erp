    <select id="HABA_YYYY_S" resultType="java.util.LinkedHashMap">
        SELECT DISTINCT YYYY FROM HABA810T_TBL WHERE CMPYCD = #{cmpycd} ORDER BY YYYY DESC
    </select>

    <select id="HABA_010U_STR" resultType="java.util.LinkedHashMap">
        exec haba_010u_str #{actkind}, #{cmpycd}, #{gubun}, #{acctcd}, #{acctnm},
        #{upacct}, #{typedc}, #{slipyn}, #{typeacct}, #{typesub}, #{typemgt},
        #{typecrs}, #{bugtcd}, #{profyn}, #{frgnyn}, #{typeect}, #{useyn}, #{keyword}, #{updemp}
    </select>

    <select id="HABA_020U_STR" resultType="java.util.LinkedHashMap">
        DECLARE @v_yyyy VARCHAR(4) = #{yyyy};
        IF ISNULL(@v_yyyy, '') = ''
           SELECT @v_yyyy = ISNULL(MAX(YYYY), '0000') FROM HABA810T_TBL WHERE CMPYCD = #{cmpycd};

        exec haba_020u_str #{actkind}, #{cmpycd}, @v_yyyy, #{gubun}, #{upacct},
        #{acctnm}, #{dbcr}, #{actgbn}, #{dspord}, #{dsprl}, #{rstyn}, #{useyn}, #{updemp}
    </select>

