    <select id="HSIP_161S_STR" resultType="java.util.LinkedHashMap">
        exec hsip_161s_str #{actkind}, #{cmpycd}, #{fileno}, #{shipseq}, #{passseq}, #{divyn}, #{itemcd}
    </select>

    <select id="HSIP_180U_STR" resultType="java.util.LinkedHashMap">
        exec hsip_180u_str #{actkind}, #{cmpycd}, #{fileno}, #{shipseq}, #{passseq},
        #{ioym}, #{iono}, #{iorowno}, #{ioamt}, #{updemp}
    </select>

    <select id="HSIP_200S_STR" resultType="java.util.LinkedHashMap">
        exec hsip_200s_str #{actkind}, #{cmpycd}, #{fileno}, #{deptcd}
    </select>

    <select id="HSIP_210S_STR" resultType="java.util.LinkedHashMap">
        exec hsip_210s_str #{cmpycd}, #{yy}, #{deptcd}
    </select>

</mapper>
