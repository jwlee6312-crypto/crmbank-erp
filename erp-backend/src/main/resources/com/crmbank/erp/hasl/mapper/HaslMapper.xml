<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.crmbank.erp.hasl.mapper.HaslMapper">

    <!-- 🔍 1. 자동분개전표 조회 (hasl_040s_str) - 기존 검증 완료본 유지 -->
    <select id="hasl_040s_str" resultType="map">
        <choose>
            <when test="search_gbn == '100' or search_gbn == 100">
                select
                    b.jurncd as jurncd, a.jurnnm as jurnnm, isnull(a.keyword,'') as keyword,
                    isnull(a.remark,'') as remark, b.jurnno as jurnno, b.acctcd as acctcd,
                    c.acctnm as acctnm, b.dbcr as dbcr, isnull(d.codenm,'') as costgbnm
                from haaa920t_tbl a
                left outer join haaa921t_tbl b on a.jurncd = b.jurncd
                left outer join haaa010t_tbl c on b.acctcd = c.acctcd
                left outer join haba900t_tbl d on a.costgbn = d.codecd and d.cdtype = '330'
                <where>
                    <if test="keywords != null and keywords.size() > 0">
                        and (
                            <foreach item="word" collection="keywords" separator="and">
                                (isnull(a.keyword,'') like '%' + #{word} + '%' or isnull(a.jurnnm,'') like '%' + #{word} + '%')
                            </foreach>
                        )
                    </if>
                </where>
                order by b.jurncd, b.jurnno
            </when>
            <otherwise>
                select
                    a.slipymd + '-' + a.slipno as jurncd, a.business as jurnnm,
                    '' as keyword, a.business as remark, b.srowno as jurnno,
                    b.acctcd as acctcd, c.acctnm as acctnm,
                    case when b.dbamt = 0 then 'c' else 'd' end as dbcr
                from hasl130t_tbl a
                left outer join hasl140t_tbl b on a.cmpycd = b.cmpycd and a.slipymd = b.slipymd and a.slipno = b.slipno
                left outer join haba010t_tbl c on b.cmpycd = c.cmpycd and b.acctcd = c.acctcd
                <where>
                    a.slipymd &gt;= convert(char(8), dateadd(mm,-24,getdate()), 112)
                    <if test="keywords != null and keywords.size() > 0">
                        and (
                            <foreach item="word" collection="keywords" separator="and">
                                isnull(a.business,'') like '%' + #{word} + '%'
                            </foreach>
                        )
                    </if>
                </where>
                order by a.slipymd desc, a.slipno desc, b.srowno
            </otherwise>
        </choose>
    </select>

    <!-- 💡 2. 상단 마스터 조회 (hasl_050u_master) - 지시하신 ASP 로직 1:1 반영 (100 제외) -->
    <select id="hasl_050u_master" resultType="map">
        <choose>
            <!-- 💡 분개유형(100)일 때는 상단 조회를 수행하지 않음 -->
            <when test="search_gbn == '100' or search_gbn == 100">
                SELECT NULL AS business WHERE 1=0
            </when>
            <when test="search_gbn == null or search_gbn == '' or search_gbn lte '   ' ">
                <!-- if SEARCHGBN <= "   " then HASL_010U_STR -->
                exec hasl_010u_str 'S', #{cmpycd}, #{slipymd}, #{slipno}, #{acctymd}, #{deptcd}, #{empnm}, '010', #{updemp}
            </when>
            <otherwise>
                <!-- else HASL_110U_STR (JURNCD 파싱) -->
                exec hasl_110u_str 'S', #{cmpycd}, substring(#{jurncd}, 1, 8), substring(#{jurncd}, 10, 3), #{acctymd}, #{deptcd}, #{empnm}, '010', #{updemp}
            </otherwise>
        </choose>
    </select>

    <!-- 💡 3. 하단 상세 내역 조회 (hasl_050u_str) - ASP 하단 로직 1:1 반영 -->
    <select id="hasl_050u_str" resultType="map">
        <choose>
            <when test="search_gbn == '100'">
                <!-- if SEARCHGBN = "100" then HASL_050U_STR -->
                exec hasl_050u_str 'S', #{cmpycd}, #{jurncd}, #{deptcd}
            </when>
            <when test="search_gbn != null and search_gbn != ''">
                <!-- else if (SEARCHGBN >= 100) then HASL_111U_STR -->
                exec hasl_111u_str 'S', #{cmpycd}, substring(#{jurncd}, 1, 8), substring(#{jurncd}, 10, 3), null, null, null, #{deptcd}, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, #{updemp}, null, null, null, null
            </when>
            <otherwise>
                <!-- else HASL_011U_STR -->
                exec hasl_011u_str 'S', #{cmpycd}, #{slipymd}, #{slipno}, null, null, null, #{deptcd}, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, #{updemp}, null, null, null, null
            </otherwise>
        </choose>
    </select>

    <!-- 기초 프로시저 규격 유지 (삭제된 부분 복구) -->
    <select id="hasl_010u_str" resultType="map">exec hasl_010u_str #{actkind}, #{cmpycd}, #{slipymd}, #{slipno}, #{acctymd}, #{deptcd}, #{empnm}, #{slipgu}, #{updemp}</select>
    <select id="hasl_110u_str" resultType="map">exec hasl_110u_str #{actkind}, #{cmpycd}, #{slipymd}, #{slipno}, #{acctymd}, #{deptcd}, #{empnm}, #{slipgu}, #{updemp}</select>
    <select id="hasl_011u_str" resultType="map">exec hasl_011u_str #{actkind}, #{cmpycd}, #{slipymd}, #{slipno}, #{srowno}, #{acctymd}, #{acctcd}, #{deptcd}, #{custcd}, #{bugtcd}, #{prjcd}, #{mgtno}, #{sslipno}, #{dbamt}, #{cramt}, #{remark}, #{paycndt}, #{payymd}, #{docno1}, #{docno2}, #{docno3}, #{docno4}, #{docno5}, #{docno6}, #{docno7}, #{docno8}, #{docno9}, #{updemp}, #{frgnkind}, #{frgnrate}, #{frgnamt}, #{ret_yn}</select>
    <select id="hasl_111u_str" resultType="map">exec hasl_111u_str #{actkind}, #{cmpycd}, #{slipymd}, #{slipno}, #{srowno}, #{acctymd}, #{acctcd}, #{deptcd}, #{custcd}, #{bugtcd}, #{prjcd}, #{mgtno}, #{sslipno}, #{dbamt}, #{cramt}, #{remark}, #{paycndt}, #{payymd}, #{docno1}, #{docno2}, #{docno3}, #{docno4}, #{docno5}, #{docno6}, #{docno7}, #{docno8}, #{docno9}, #{updemp}, #{frgnkind}, #{frgnrate}, #{frgnamt}, #{ret_yn}</select>
</mapper>
