<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.crmbank.erp.hfba.mapper.HfbaMapper">

    <select id="FBA1010U_STR" resultType="map">
        EXEC FBA1010U_STR #{CMPYCD}, #{ACTKIND}, #{CDKD}, #{CODE},
            #{CDNM}, #{REMARK}, #{DISPORD},  #{USEYN}, #{USERID}
    </select>

    <select id="FBA1040U_STR" resultType="map">
        EXEC FBA1040U_STR #{CMPYCD}, #{ACTKIND}, #{YM}, #{ACCT}, #{ACCTNM},
        #{DIVIDE1}, #{DIVIDE2}, #{DIVIDE3}, #{DIVIDE4}, #{DIVIDE5}, #{DIVIDE6}, #{DIVIDE7},
        #{BIGO}, #{USERID}
    </select>

    <select id="FBA1060U_STR" resultType="map">
        EXEC FBA1060U_STR #{CMPYCD}, #{ACTKIND}, #{YM}, #{COSTCD}, #{DIVSTD}, #{JSANGBN},
        #{ITEMCD}, #{UNIT}, #{ITEMNM}, #{UNITAMT}, #{BIGO}, #{USERID}
    </select>

    <select id="FBA2010U_STR" resultType="map">
        EXEC FBA2010U_STR #{CMPYCD}, #{ACTKIND}, #{ACCT}, #{ACCT_O}, #{ACCTNM}, #{BIGO}, #{USEYN}, #{ACNTGBN}, #{USERID}

    </select>

    <select id="FBA3010U_STR" resultType="map">
        EXEC FBA3010U_STR #{CMPYCD},#{ACTKIND},#{YYMM}, #{YN}, #{REMARK}, #{USERID}
    </select>

    <!-- 💡 계정과목 직접 조회 -->
    <select id="selectAcctList" resultType="map">
        SELECT ACCT, ACCTNM
        FROM FBA2020T_TBL
        WHERE CMPYCD = #{CMPYCD} AND USEYN = 'Y'
        ORDER BY ACCT
    </select>

    <!-- 💡 공정배부/품목배부 기준 직접 조회 -->
    <select id="selectDivideList" resultType="map">
        SELECT CODE, CDNM
        FROM FBA1010T_TBL
        WHERE CMPYCD = #{CMPYCD}
        AND CDKD = #{CDKD}
        AND USEYN = 'Y'
        ORDER BY DISPORD
    </select>

    <!-- 💡 배부적수 목록 직접 조회 -->
    <select id="selectDivideJuksuList" resultType="map">
        SELECT A.ITEMCD,
               B.ITEMNM,
               B.UNIT,
               A.UNITAMT,
               A.BIGO
        FROM FBA1060T_TBL A
        INNER JOIN P_ITEM_TBL B ON A.CMPYCD = B.CMPYCD AND A.ITEMCD = B.ITEMCD
        WHERE A.CMPYCD = #{CMPYCD}
          AND A.YYMM   = #{YM}
          AND A.DIVSTD = #{DIVSTD}
          AND A.JSANGBN = #{JSANGBN}
        ORDER BY A.ITEMCD
    </select>

</mapper>
