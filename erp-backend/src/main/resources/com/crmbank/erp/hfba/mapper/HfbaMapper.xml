<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.crmbank.erp.hfba.mapper.HfbaMapper">

    <select id="FBA1010U_STR" resultType="java.util.LinkedHashMap">
        exec fba1010u_str #{cmpycd}, #{actkind}, #{cdkd}, #{code},
            #{cdnm}, #{remark}, #{dispord},  #{useyn}, #{userid}
    </select>

    <select id="FBA1040U_STR" resultType="java.util.LinkedHashMap">
        exec fba1040u_str #{cmpycd}, #{actkind}, #{ym}, #{acct}, #{acctnm},
        #{divide1}, #{divide2}, #{divide3}, #{divide4}, #{divide5}, #{divide6}, #{divide7},
        #{bigo}, #{userid}
    </select>

    <select id="FBA1060U_STR" resultType="java.util.LinkedHashMap">
        exec fba1060u_str #{cmpycd}, #{actkind}, #{ym}, #{costcd}, #{divstd}, #{jsangbn},
        #{itemcd}, #{unit}, #{itemnm}, #{unitamt}, #{bigo}, #{userid}
    </select>

    <select id="FBA2010U_STR" resultType="java.util.LinkedHashMap">
        exec fba2010u_str #{cmpycd}, #{actkind}, #{acct}, #{acct_o}, #{acctnm}, #{bigo}, #{useyn}, #{acntgbn}, #{userid}
    </select>

    <select id="FBA3010U_STR" resultType="java.util.LinkedHashMap">
        exec fba3010u_str #{cmpycd}, #{actkind}, #{yymm}, #{yn}, #{remark}, #{userid}
    </select>

    <select id="FBA2020U_SEL" resultType="java.util.LinkedHashMap">
        exec fba2020u_sel #{cmpycd}, #{actkind}, #{yyyy}, #{gubun}, #{prtseq}
    </select>

    <select id="FBA2020U_MOD" resultType="java.util.LinkedHashMap">
        exec fba2020u_mod #{cmpycd}, #{actkind}, #{yyyy}, #{gubun}, #{prtseq}, #{prtacct}, #{prtacctnm},
        #{dspyn}, #{dsprl}, #{upacct}, #{calseq}, #{calacct}, #{calacctnm}, #{dc}, #{calcaulm},
        #{calcaulmnm}, #{calgagam}, #{bigo}, #{updemp}
    </select>

    <select id="FBA2020U_DEL" resultType="java.util.LinkedHashMap">
        exec fba2020u_del #{cmpycd}, #{actkind}, #{yyyy}, #{gubun}, #{prtseq}, #{calseq}
    </select>

    <!-- 💡 계정과목 직접 조회 -->
    <select id="selectAcctList" resultType="java.util.LinkedHashMap">
        select acct, acctnm
        from fba2020t_tbl
        where cmpycd = #{cmpycd} and useyn = 'y'
        order by acct
    </select>

    <!-- 💡 공정배부/품목배부 기준 직접 조회 -->
    <select id="selectDivideList" resultType="java.util.LinkedHashMap">
        select code, cdnm
        from fba1010t_tbl
        where cmpycd = #{cmpycd}
        and cdkd = #{cdkd}
        and useyn = 'y'
        order by dispord
    </select>

    <!-- 💡 배부적수 목록 직접 조회 -->
    <select id="selectDivideJuksuList" resultType="java.util.LinkedHashMap">
        select a.itemcd,
               b.itemnm,
               b.unit,
               a.unitamt,
               a.bigo
        from fba1060t_tbl a
        inner join p_item_tbl b on a.cmpycd = b.cmpycd and a.itemcd = b.itemcd
        where a.cmpycd = #{cmpycd}
          and a.yymm   = #{ym}
          and a.divstd = #{divstd}
          and a.jsangbn = #{jsangbn}
        order by a.itemcd
    </select>

</mapper>
