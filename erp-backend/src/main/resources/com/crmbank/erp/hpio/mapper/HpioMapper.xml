    </select>

    <!-- 제품입고현황(상세) -->
    <select id="HPIO_430S_STR" resultType="java.util.LinkedHashMap">
        exec hpio_430s_str #{cmpycd}, #{whcd}, #{itemcd}, #{fromdt}, #{todt}
    </select>

    <!-- 이관출고 MASTER -->
    <select id="HPIO_500U_STR" resultType="java.util.LinkedHashMap">
        exec hpio_500u_str #{actkind}, #{cmpycd}, #{fromdt}, #{todt}, #{iogbn}, #{ioym}, #{iono},
        #{prodcd}, #{linecd}, #{progcd}, #{outymd}, #{odeptcd}, #{owhcd}, #{ocustcd}, #{itemcd},
