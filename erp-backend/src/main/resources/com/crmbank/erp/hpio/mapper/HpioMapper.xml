        #{linecd}, #{progcd}, #{odeptcd}, #{owhcd}, #{custcd}, #{ioymd}, #{ideptcd},
        #{iwhcd}, #{itemcd}, #{unit}, #{ioqty}, #{ordym}, #{ordno}, #{updemp}
    </select>

