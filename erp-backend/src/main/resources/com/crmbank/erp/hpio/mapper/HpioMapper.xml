        #{progcd}, #{slipyn}, #{iogbn}, #{ioym}, #{iono}, #{custcd}, #{prodcd}
    </select>

    <!-- 외주가공생산실적등록 -->
    <select id="HPIO_870U_STR" resultType="java.util.LinkedHashMap">
        exec hpio_870u_str #{actkind}, #{cmpycd}, #{fromdt}, #{todt}, #{linecd},
        #{progcd}, #{slipyn}, #{iogbn}, #{ioym}, #{iono}, #{custcd}, #{prodcd}, #{updemp}
    </select>

    <!-- 작업지시 팝업 조회 (HPIO250U용) -->
    <select id="HPIO_250U_POP" resultType="java.util.LinkedHashMap">
        select a.linecd, a.lotymd, a.lotno, a.itemcd as itemcd, b.itemnm as itemnm, a.itsize, a.unit,
               isnull(a.ordqty, 0) as ordqty, isnull(a.outqty, 0) as outqty,
               isnull(a.prodqty, 0) as prodqty, c.linenm, a.gubun, a.ordym, a.ordno
        from HPIO210T_TBL a
        left join HSBA010T_TBL b on a.cmpycd = b.cmpycd and a.itemcd = b.itemcd
        left join HPBA130T_TBL c on a.cmpycd = c.cmpycd and a.linecd = c.linecd
        where a.cmpycd = #{cmpycd}
          and a.linecd = #{linecd}
          and a.ordymd between #{frymd} and #{toymd}
          and isnull(a.ordqty, 0) > isnull(a.outqty, 0)
    </select>

    <!-- 자재불출요청 상세 (상세내역용) -->
    <select id="HPIO_251S_STR" resultType="java.util.LinkedHashMap">
        exec hpio_251s_str #{cmpycd}, #{fromdt}, #{todt}
    </select>

    <select id="HPIO_252S_STR" resultType="java.util.LinkedHashMap">
        exec hpio_252s_str #{cmpycd}, #{fromdt}, #{todt}
    </select>

    <!-- 자재불출 품목내역 처리 (집계테이블) -->
    <select id="HPIO_253U_STR" resultType="java.util.LinkedHashMap">
        exec hpio_253u_str #{actkind}, #{cmpycd}, #{outym}, #{outno}, #{mitemcd}, #{mitsize}, #{munit}, #{reqqty}, #{updemp}
    </select>

    <select id="HPIO_340U_POPUP" parameterType="map">
        select a.pumym, a.pumno,  a.custcd, i.custnm, j.deptnm, k.usernm,
            a.pumymd,b.itemcd, e.itemnm, e.itsize,e.unit,   b.price
            from hpba300t_tbl a left outer join hpba301t_tbl b
            on a.cmpycd = b.cmpycd
            and a.pumym = b.pumym
            and a.pumno = b.pumno
            left outer join hsba010t_tbl e
            on b.cmpycd  = e.cmpycd
            and b.itemcd  = e.itemcd
            left outer join haba020t_tbl i
            on a.cmpycd = i.cmpycd and a.custcd = i.custcd
            left outer join haba120t_tbl j
            on a.cmpycd = j.cmpycd and a.deptcd = j.deptcd
            left outer join haba920t_tbl k
            on a.cmpycd = k.cmpycd
            and a.updemp = k.userid
      where a.cmpycd  =  #{cmpycd}
        and a.pumymd between  #{fromdt} and  #{todt}
    </select>
</mapper>
